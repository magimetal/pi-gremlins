{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022"],
		"types": ["node"],
		"strict": false,
		"skipLibCheck": true,
		"noEmit": true,
		"allowJs": false,
		"verbatimModuleSyntax": true,
		"resolveJsonModule": true
	},
	"include": ["extensions/pi-gremlins/**/*.ts"],
	"exclude": ["node_modules"]
}
